#
# NickelCoverFix configuration
#
# Keeps your book covers showing even when Kobo can't fetch them (offline, or after a sync changes the
# cover id). It mirrors the cover Kobo itself already had — keyed by the book's stable ContentID — and
# shows that. No book files are read, nothing is decrypted, and Kobo's own cache (.kobo-images) is never
# written. Remove the mod (or this folder) to fully revert.
#
# The mod is active on install. Changes below take effect on reboot. To disable it, set ncf_enabled:0
# (over USB) and reboot; to remove it, delete the `uninstall` file in this folder and reboot.
#
# Covers are mirrored automatically as books are shown (owned books only — store/recommendation covers are
# never touched), or all at once via  More > Repair Book Covers. If a book's cover was never available to
# begin with, run Settings > "Repair your Kobo account" (online) to fetch covers, then Repair Book Covers.

# Master kill-switch. 0 = everything inert (works like stock).
ncf_enabled:1

# CAPTURE: mirror each owned book's cover as it's shown (raw copy from Kobo's cache, or the rendered image
# for covers not on disk). Once per book per session. 0 = only the manual "Repair Book Covers" populates.
ncf_capture:1

# SERVE: show our mirrored cover instead of the placeholder when a cover is unavailable.
ncf_serve:1

# Add the "Repair Book Covers" row to the More page (mirrors your whole library at once, with a progress bar).
ncf_menu:1

# Log to nickel-cover-fix.log. 0 disables persistent file logging.
ncf_log:1

# ─── COVER MODE ───────────────────────────────────────────────────────────────────────────────────────
# 1 = scoped override: for every LIBRARY book we can make a cover for, show our own copy. Store items,
#     recommendations, previews and new/cloud books have no cover for us to copy, so they fall through to
#     Kobo's normal path untouched. Offline-consistent for your library, no regression elsewhere.
# 0 = graceful fallback: show Kobo's real cover when it's available, and use our copy only to replace a
#     placeholder (offline / changed cover id). The most conservative option.
ncf_force_serve:1

# DEBUG: stamp a bullseye on covers we serve, so you can see which come from this mod. Leave 0 normally.
ncf_debug_dot:0
